config ZMK_INPUT_PROCESSOR_KEY
    bool "ZMK Input Processor: XY-to-Arrow-Key conversion"
    default y if DT_HAS_ZMK_INPUT_PROCESSOR_KEY_ENABLED
    depends on ZMK_POINTING
    help
      Enables the zmk,input-processor-key driver which accumulates
      trackball/mouse XY movement and converts it into discrete
      keyboard arrow-key HID reports.  Mirrors the behaviour of
      TrackballArrows.ahk: movement past a threshold fires one key
      press/release cycle; a burst cap limits events per poll cycle.
